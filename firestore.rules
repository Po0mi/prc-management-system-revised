rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User registry — any authenticated user can read; only self can write
    match /userRegistry/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Conversations — any authenticated user who is a participant can read/write
    // Participants are stored as PHP user_id strings (e.g. "5", "7")
    match /conversations/{conversationId} {
      allow read, write: if request.auth != null;

      // Messages subcollection — any authenticated user can read/write
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
